{
  "expo": {
    "name": "Speedza",
    "slug": "speedza",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "speedza",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "bundleIdentifier": "com.speedza.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to show nearby stores."
      }
    },
    "android": {
      "package": "com.speedza.app",
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6ef242a0-a55d-4205-bc66-2bc935463675"
      }
    }
  }
}
