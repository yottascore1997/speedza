# Copy to ".env" for local dev. For Play Store builds, set the same names in
# Expo → Project → Environment variables (development / preview / production).

EXPO_PUBLIC_API_URL=https://your-next-app.example.com

# Optional if web shop URL differs from API host (see lib/web-base.ts)
# EXPO_PUBLIC_WEB_URL=https://your-next-app.example.com

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# NEXT_PUBLIC_* variants are also read by app.config.js / firebase-client if you reuse web keys.
